// #FILE: failure.mpp, Component Module Interface File
// #BRIEF: Module interface file for failure component.

module;

#include "core.hpp" // #INCLUDE: core.hpp, Package wide header

// #MODULE: docme.core:failure, Component Module Partition
// #BRIEF: Module partition for failure tools.
export module docme.core:failure;

import :errors; // #IMPORT: docme.core:errors, Project error type
import :warnings; // #IMPORT: docme.core:warnings, Project warning type

namespace docme::core{ // #SCOPE: docme::core

    // #CLASS: Failure, Exported Final Class
    // #BRIEF: Represents a failure state with an error and warnings.
    export class Failure final{
    public: // #DIV: Public
    // Public Special Methods
        Failure(Error&& p_error, std::vector<Warning>&& p_warnings);
    // Public Operators
        const Error& operator*()const&;
        Error operator*()&&;
    // Public Methods
        bool hasWarnings()const;
        const Error& error()const;
        const std::vector<Warning>& warnings()const;
        std::vector<Warning> warnings()&&;
        std::vector<Warning> takeWarnings();
        void propagateWarnings(const std_loc& p_callSite = std_loc::current());
        const Error& value()const;
        Error takeValue();
    private: // #DIV: Private
    // Private Fields
        Error m_error;
        std::vector<Warning> m_warnings;
    }; // #END: Failure

} // #END: docme::core